double calculateEMI(double P, double R = 0.01, int T = 12) {
    if (R == 0.0) {
        return P / T;
    }
    double r = R / 12.0;
    double emi = (P * r * pow(1 + r, T)) / (pow(1 + r, T) - 1);
    return emi;
}

