#include <iostream>

int digitSum(int n) {
    if (n == 0) {
        return 0;
    } else {
        return (n % 10) + digitSum(n / 10);
    }
}

int main() {
    int N;
    std::cin >> N;
    std::cout << digitSum(N) << std::endl;
    return 0;
}
