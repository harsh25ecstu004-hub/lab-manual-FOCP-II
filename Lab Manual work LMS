#include <iostream>
#include <cmath>

using namespace std;

bool isPrime(int n) {
    if (n <= 1) return false;
    for (int i = 2; i * i <= n; i++) {
        if (n % i == 0) return false;
    }
    return true;
}

int main() {
    int n;
    if (!(cin >> n)) return 1;
    if (isPrime(n)) {
        cout << "Prime" << endl;
    } else {
        cout << "Not Prime" << endl;
    }
    return 0;
}


#include <iostream>

void swapByValue(int a, int b) {
    int temp = a;
    a = b;
    b = temp;
}

void swapByReference(int &a, int &b) {
    int temp = a;
    a = b;
    b = temp;
}

bool isPrime(int n) {
    if (n <= 1) {
        return false;
    }
    for (int i = 2; i * i <= n; ++i) {
        if (n % i == 0) {
            return false;
        }
    }
    return true;
}

int main() {
    int a, b;
    if (!(std::cin >> a >> b)) {
        return 1;
    }

    std::cout << "Prime Check for " << a << ": " << (isPrime(a) ? "True" : "False") << std::endl;
    std::cout << "Prime Check for " << b << ": " << (isPrime(b) ? "True" : "False") << std::endl;

    std::cout << "Original values: a = " << a << ", b = " << b << std::endl;

    swapByValue(a, b);
    std::cout << "After swapByValue: a = " << a << ", b = " << b << std::endl;

    swapByReference(a, b);
    std::cout << "After swapByReference: a = " << a << ", b = " << b << std::endl;

    return 0;
}



#include <iostream>
#include <climits>

void findMinMax(int arr[], int size, int &minVal, int &maxVal) {
    if (size <= 0) return;

    minVal = INT_MAX;
    maxVal = INT_MIN;

    for (int i = 0; i < size; ++i) {
        if (arr[i] < minVal) {
            minVal = arr[i];
        }
        if (arr[i] > maxVal) {
            maxVal = arr[i];
        }
    }
}

int main() {
    int N;
    if (!(std::cin >> N)) return 0;

    int* arr = new int[N];
    for (int i = 0; i < N; ++i) {
        std::cin >> arr[i];
    }

    int minVal, maxVal;
    findMinMax(arr, N, minVal, maxVal);

    if (N > 0) {
        std::cout << minVal << " " << maxVal << std::endl;
    }

    delete[] arr;
    return 0;
}



